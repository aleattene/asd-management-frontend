# Django/DRF API base URL, for example:
# VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=
# Enable mock authentication for local/demo environments only.
VITE_ENABLE_MOCK_AUTH=false
# Relative JWT login path, for example: auth/token
VITE_AUTH_LOGIN_PATH=
# Relative JWT refresh path, for example: auth/token/refresh
VITE_AUTH_REFRESH_PATH=

VITE_APP_NAME=ASD Management
VITE_ASSOCIATION_NAME=
VITE_APP_TAGLINE=
VITE_SUPPORT_EMAIL=
